<div class="gmt-app-body">
  <form class="gmt-form">

    {{!-- ===== Encounter Parameters ===== --}}
    <section class="gmt-section">
      <h3 class="gmt-section-title">Party</h3>
      <div class="gmt-row">
        <div class="gmt-field">
          <label for="partyLevel">
            Party Level
            {{#if detectedPartyLevel}}<span class="gmt-detected">(detected: {{detectedPartyLevel}})</span>{{/if}}
          </label>
          <input type="number" name="partyLevel" id="partyLevel" min="1" max="20"
            value="{{#if detectedPartyLevel}}{{detectedPartyLevel}}{{else}}5{{/if}}">
        </div>
        <div class="gmt-field">
          <label for="partySize">
            Party Size
            {{#if detectedPartySize}}<span class="gmt-detected">(detected: {{detectedPartySize}})</span>{{/if}}
          </label>
          <input type="number" name="partySize" id="partySize" min="1" max="8"
            value="{{#if detectedPartySize}}{{detectedPartySize}}{{else}}4{{/if}}">
        </div>
      </div>
    </section>

    <section class="gmt-section">
      <h3 class="gmt-section-title">Encounter Settings</h3>

      <div class="gmt-field">
        <label for="terrain">Terrain</label>
        <select name="terrain" id="terrain">
          {{#each terrainOptions}}
            {{!-- Pre-select the terrain tag stored on the active scene (if any). --}}
            <option value="{{value}}" {{#if (eq value ../detectedTerrain)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="gmt-field">
        <label for="genMode">Generation Mode</label>
        <select name="genMode" id="genMode">
          <option value="random">Random (weighted template)</option>
          <option value="template">Choose Template</option>
          <option value="custom">Custom (choose difficulty)</option>
        </select>
      </div>

      <div class="gmt-field template-row" hidden>
        <label for="templateKey">Template</label>
        <select name="templateKey" id="templateKey">
          {{#each templateOptions}}
            <option value="{{value}}">{{label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="gmt-field difficulty-row" hidden>
        <label for="difficulty">Difficulty</label>
        <select name="difficulty" id="difficulty">
          {{#each difficultyOptions}}
            <option value="{{value}}" {{#if (eq value "moderate")}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>

      {{#if hasGeminiKey}}
        <div class="gmt-field gmt-checkbox">
          <label>
            <input type="checkbox" name="useAI" checked>
            AI Narrative Enhancement
          </label>
        </div>
      {{else}}
        <p class="gmt-hint">Configure an AI provider in Module Settings to enable narrative enhancement.</p>
      {{/if}}
    </section>

    {{!-- ===== Action Buttons ===== --}}
    <div class="gmt-actions">
      <button type="button" data-action="generate" {{#if isGenerating}}disabled{{/if}}>
        {{#if isGenerating}}
          <i class="fas fa-spinner fa-spin"></i> Generating…
        {{else}}
          <i class="fas fa-dice-d20"></i> Generate Encounter
        {{/if}}
      </button>
    </div>
  </form>

  {{!-- ===== Result Panel ===== --}}
  {{#if hasResult}}
  <section class="gmt-result">
    <div class="gmt-result-header">
      <h3>{{encounter.templateName}}</h3>
      {{!-- Show a prominent notice when a boss is locked so the GM always knows
           the encounter is in pinned mode and regenerate will only swap supporters. --}}
      {{#if hasPinnedBoss}}
      <p class="gmt-boss-locked-note">
        <i class="fas fa-thumbtack"></i> Boss locked: <strong>{{pinnedBossName}}</strong>
        — Regenerate replaces supporters only.
      </p>
      {{/if}}
      <div class="gmt-result-meta">
        <span class="gmt-badge difficulty-{{encounter.difficulty}}">{{encounter.difficulty}}</span>
        <span>Level {{encounter.partyLevel}} · {{encounter.partySize}} players</span>
        <span>{{lookup terrainLabels encounter.terrain}}</span>
      </div>
      <p class="gmt-xp">
        {{#if encounter.actualXP}}
          XP Budget: {{encounter.xpBudget}} (Actual: {{encounter.actualXP}})
        {{else}}
          XP Budget: {{encounter.xpBudget}}
          {{#if encounter.baseXP}}(base {{encounter.baseXP}}){{/if}}
        {{/if}}
      </p>
    </div>

    <table class="gmt-creature-table">
      <thead>
        <tr>
          <th>Creature</th>
          <th>Role</th>
          <th>Lvl</th>
          <th>HP</th>
          <th>AC</th>
          <th>XP ea.</th>
          <th class="gmt-boss-col">Boss</th>
        </tr>
      </thead>
      <tbody>
        {{#each summary}}
        {{!-- Add a CSS class to the boss row so it can be styled distinctly. --}}
        <tr class="{{#if isBoss}}gmt-boss-row{{/if}}">
          <td>
            {{!-- Render a clickable button when compendium identifiers are available,
                 so the GM can open the full statblock sheet with one click. --}}
            {{#if packId}}
              {{#if actorId}}
                <button type="button" class="gmt-link-btn" data-action="openSheet"
                  data-pack-id="{{packId}}" data-actor-id="{{actorId}}">
                  {{#if (gt count 1)}}{{count}}× {{/if}}{{name}}
                  {{#if remaster}}<em class="gmt-remaster">[R]</em>{{/if}}
                </button>
              {{else}}
                {{#if (gt count 1)}}{{count}}× {{/if}}{{name}}
                {{#if remaster}}<em class="gmt-remaster">[R]</em>{{/if}}
              {{/if}}
            {{else}}
              {{#if (gt count 1)}}{{count}}× {{/if}}{{name}}
              {{#if remaster}}<em class="gmt-remaster">[R]</em>{{/if}}
            {{/if}}
          </td>
          <td>{{role}}</td>
          <td>{{level}}</td>
          <td>{{hp}}</td>
          <td>{{ac}}</td>
          <td>{{xpEach}}</td>
          <td class="gmt-boss-col">
            {{#if isBoss}}
              {{!-- This row IS the pinned boss — show a badge and an unpin button. --}}
              <span class="gmt-boss-badge" title="Pinned boss">
                <i class="fas fa-crown"></i>
              </span>
              <button type="button" class="gmt-unpin-btn" data-action="unpinBoss"
                title="Unpin boss">
                <i class="fas fa-times"></i>
              </button>
            {{else}}
              {{!-- Allow any non-boss row to become the new boss. --}}
              <button type="button" class="gmt-pin-btn" data-action="pinBoss"
                data-boss-actor-id="{{actorId}}"
                data-boss-name="{{name}}"
                title="Pin as boss">
                <i class="fas fa-thumbtack"></i>
              </button>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    {{#if encounter.aiNarrative}}
    <div class="gmt-narrative">
      <h4>Setting</h4>
      <p>{{encounter.aiNarrative.setting_description}}</p>
      <h4>The Encounter</h4>
      <p>{{encounter.aiNarrative.monster_description}}</p>
      <h4>Hook</h4>
      <p>{{encounter.aiNarrative.encounter_hook}}</p>
      <h4>Tactical Notes</h4>
      <p>{{encounter.aiNarrative.tactical_notes}}</p>
      <h4>Battle Map Setup</h4>
      <p>{{encounter.aiNarrative.battle_map_details}}</p>
    </div>
    {{!-- Share Narrative row — only shown when AI narrative is present. --}}
    <div class="gmt-share-actions">
      <button type="button" data-action="shareAINarrative">
        <i class="fas fa-comment-alt"></i> Share Narrative
      </button>
    </div>
    {{/if}}

    {{!-- Token placement options shown only when a result exists. --}}
    {{#if hasResult}}
    <div class="gmt-placement-controls">
      <label class="gmt-checkbox">
        <input type="checkbox" name="tokensHidden" checked>
        Hidden from players
      </label>
      <label class="gmt-checkbox">
        <input type="checkbox" name="addToCombat">
        Add to combat tracker
      </label>
    </div>
    {{/if}}

    <div class="gmt-result-actions">
      <button type="button" data-action="saveJournal">
        <i class="fas fa-book"></i> Save to Journal
      </button>
      {{!-- Place Tokens requires an active scene; disabled otherwise to avoid silent failure. --}}
      {{#if hasActiveScene}}
        <button type="button" data-action="placeTokens">
          <i class="fas fa-map-marker-alt"></i> Place Tokens
        </button>
      {{else}}
        <button type="button" disabled title="No active scene">
          <i class="fas fa-map-marker-alt"></i> Place Tokens
        </button>
      {{/if}}
      <button type="button" data-action="clearResult" class="gmt-secondary">
        <i class="fas fa-times"></i> Clear
      </button>
    </div>
  </section>
  {{/if}}
</div>
