<div class="gmt-app-body">
  <form class="gmt-form">

    <section class="gmt-section">
      <h3 class="gmt-section-title">Options</h3>

      {{!-- NPC Purpose — drives occupation pool and archetype category pre-filter --}}
      <div class="gmt-field">
        <label for="npcPurpose">NPC Purpose</label>
        <select name="npcPurpose" id="npcPurpose" data-action="changePurpose">
          {{#each npcPurposeOptions}}
            <option value="{{value}}" {{#if (eq value ../npcPurpose)}}selected{{/if}}>
              {{label}}
            </option>
          {{/each}}
        </select>
        {{#unless (eq npcPurpose "any")}}
          <p class="gmt-hint" style="margin-top:0.2rem;">
            Occupation and archetype category pre-filtered for <em>{{npcPurposeLabel}}</em>.
          </p>
        {{/unless}}
      </div>

      {{#if hasGeminiKey}}
        <div class="gmt-field gmt-checkbox">
          <label>
            <input type="checkbox" name="useAI" checked>
            AI-Enhanced — appearance, motivation, secret, quote
          </label>
        </div>
      {{else}}
        <p class="gmt-hint">Configure an AI provider in Module Settings to enable AI-enhanced NPCs.</p>
        <p class="gmt-hint">Basic mode: random name, race, occupation, personality trait.</p>
      {{/if}}

      {{!-- Creature level for archetype matching. Shows (auto-detected) when
            the value is coming from the party rather than a manual override.
            Min is -1 because PF2e uses -1 and 0 for ordinary commoners. --}}
      <div class="gmt-field gmt-row" style="align-items:center; gap:0.5rem; margin-top:0.35rem;">
        <label style="font-size:var(--font-size-12); font-weight:500; color:var(--color-text-secondary); white-space:nowrap;">
          Creature Level
          {{#if usingDetected}}<span class="gmt-detected">(auto-detected)</span>{{/if}}
        </label>
        <input type="number" name="creatureLevel" min="-1" max="20"
               value="{{effectiveLevel}}"
               style="width:60px; height:26px; padding:0 0.3rem;">
      </div>
      {{!-- Dynamic role hint — updates whenever effectiveLevel changes. --}}
      <p class="gmt-hint gmt-level-role">Level {{effectiveLevel}}: {{levelRole}}</p>
    </section>

    <div class="gmt-actions">
      <button type="button" data-action="generate" {{#if isGenerating}}disabled{{/if}}>
        {{#if isGenerating}}
          <i class="fas fa-spinner fa-spin"></i> Generating…
        {{else}}
          <i class="fas fa-user-plus"></i> Generate NPC
        {{/if}}
      </button>
    </div>
  </form>

  {{#if hasResult}}
  <section class="gmt-result">
    <div class="gmt-npc-header">
      <h3>{{npc.name}}</h3>
      <div class="gmt-result-meta">
        <span>{{npc.race}}</span>
        <span>{{npc.sex}}</span>
        {{#if npc.aiEnhanced}}<span class="gmt-badge gmt-ai-badge">AI Enhanced</span>{{/if}}
      </div>
    </div>

    <dl class="gmt-npc-details">
      <dt>Occupation</dt>
      <dd>{{npc.occupation}}</dd>

      <dt>Personality</dt>
      <dd>{{npc.personality}}</dd>

      {{#if npc.appearance}}
        <dt>Appearance</dt>
        <dd>{{npc.appearance}}</dd>
      {{/if}}

      {{#if npc.motivation}}
        <dt>Motivation</dt>
        <dd>{{npc.motivation}}</dd>
      {{/if}}

      {{#if npc.secret}}
        <dt>Secret</dt>
        <dd>{{npc.secret}}</dd>
      {{/if}}

      {{#if npc.quote}}
        <dt>Quote</dt>
        <dd><em>"{{npc.quote}}"</em></dd>
      {{/if}}
    </dl>

    <div class="gmt-result-actions">
      {{!-- Share NPC Details — only available when AI enhancement was applied. --}}
      {{#if npc.aiEnhanced}}
      <button type="button" data-action="shareNPCNarrative">
        <i class="fas fa-comment-alt"></i> Share NPC Details
      </button>
      {{/if}}
      <button type="button" data-action="saveJournal">
        <i class="fas fa-book"></i> Save to Journal
      </button>
      <button type="button" data-action="clearResult" class="gmt-secondary">
        <i class="fas fa-times"></i> Clear
      </button>
    </div>
  </section>

  {{!-- ---- Archetype picker — optional stat block base ---- --}}
  <section class="gmt-section gmt-archetype-section">
    <h3 class="gmt-section-title">Archetype (Optional)</h3>
    <p class="gmt-hint">Select a compendium NPC as the mechanical base. Without one, the actor will have no combat stats.</p>

    {{#if selectedArchetype}}
      {{!-- Show the confirmed selection and offer a clear button. --}}
      <div class="gmt-selected-archetype">
        <span><i class="fas fa-check-circle"></i> {{selectedArchetype.name}}</span>
        <button type="button" data-action="clearArchetype" class="gmt-secondary">
          <i class="fas fa-times"></i> Clear
        </button>
      </div>
    {{else}}
      {{!-- No selection yet — show the browse/hide toggle. --}}
      <button type="button" data-action="toggleArchetypePicker">
        <i class="fas fa-search"></i>
        {{#if showArchetypePicker}}Hide Picker{{else}}Browse Archetypes{{/if}}
      </button>
    {{/if}}

    {{#if showArchetypePicker}}
    <div class="gmt-archetype-picker">
      <div class="gmt-archetype-filters">
        <select name="archetypeCategory">
          {{#each archetypeCategories}}
            <option value="{{this}}"
              {{#if (eq this ../archetypeCategory)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
        <button type="button" data-action="applyArchetypeFilter">Filter</button>
        <span class="gmt-hint">{{archetypes.length}} shown (level ~{{effectiveLevel}})</span>
      </div>

      <div class="gmt-archetype-list">
        {{#each archetypes}}
        <button type="button" class="gmt-archetype-entry" data-action="selectArchetype"
          data-pack-id="{{packId}}" data-actor-id="{{actorId}}" data-name="{{name}}">
          <span class="gmt-arch-name">{{name}}</span>
          <span class="gmt-arch-right">
            {{!-- Source badge: NPC Gallery gets a highlighted pill; bestiary gets a muted one. --}}
            {{#if (eq source "npc-gallery")}}
              <span class="source-badge npc-gallery">NPC Gallery</span>
            {{else}}
              <span class="source-badge bestiary">Bestiary</span>
            {{/if}}
            <span class="gmt-arch-meta">Lvl {{level}} · {{category}}</span>
          </span>
        </button>
        {{else}}
        <p class="gmt-hint" style="padding:0.5rem;">
          No archetypes found at this level. Try adjusting the level or category.
        </p>
        {{/each}}
      </div>
    </div>
    {{/if}}

    <div class="gmt-result-actions">
      <button type="button" data-action="createActor">
        <i class="fas fa-user-plus"></i>
        {{#if shopType}}
          Create Actor + Generate Inventory
        {{else}}
          {{#if selectedArchetype}}Create Actor (with archetype){{else}}Create Actor (no stats){{/if}}
        {{/if}}
      </button>
    </div>
  </section>

  {{!-- ---- Merchant section — optional shop inventory generation ---- --}}
  <section class="gmt-section gmt-merchant-section">
    <h3 class="gmt-section-title">Merchant (Optional)</h3>

    {{#if shopType}}
      {{!-- Merchant mode active: show shop configuration controls. --}}
      <div class="gmt-merchant-controls">
        <div class="gmt-field">
          <label>Shop Type</label>
          {{!-- data-action fires _onShopTypeChange so the app state stays in sync
               without needing a separate form-submit step. --}}
          <select name="shopType" data-action="shopTypeChange">
            {{#each shopTypeOptions}}
              <option value="{{value}}" {{#if (eq value ../shopType)}}selected{{/if}}>
                {{label}}
              </option>
            {{/each}}
          </select>
        </div>
        <div class="gmt-field">
          <label>Wealth Tier</label>
          <select name="wealthTier">
            <option value="poor"     {{#if (eq ../wealthTier "poor")}}selected{{/if}}>Poor (lv -2)</option>
            <option value="standard" {{#if (eq ../wealthTier "standard")}}selected{{/if}}>Standard (lv ±0)</option>
            <option value="wealthy"  {{#if (eq ../wealthTier "wealthy")}}selected{{/if}}>Wealthy (lv +1)</option>
            <option value="elite"    {{#if (eq ../wealthTier "elite")}}selected{{/if}}>Elite (lv +2)</option>
          </select>
        </div>
        <div class="gmt-field">
          <label>Location Size</label>
          <select name="locationSize">
            <option value="village" {{#if (eq ../locationSize "village")}}selected{{/if}}>Village (8-10 items)</option>
            <option value="town"    {{#if (eq ../locationSize "town")}}selected{{/if}}>Town (12-15 items)</option>
            <option value="city"    {{#if (eq ../locationSize "city")}}selected{{/if}}>City (18-22 items)</option>
          </select>
        </div>
        <button type="button" data-action="clearMerchant" class="gmt-secondary">
          <i class="fas fa-times"></i> Remove Merchant
        </button>
      </div>
    {{else}}
      {{!-- Merchant mode inactive: show the activation button. --}}
      <button type="button" data-action="enableMerchant">
        <i class="fas fa-store"></i> Make Merchant
      </button>
    {{/if}}
  </section>
  {{/if}}
</div>
